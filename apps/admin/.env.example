# ── Database ──────────────────────────────────────────────────────────────────
PLATFORM_DATABASE_URL=postgresql://user:password@host:5432/platform?sslmode=require

# ── Auth (Better Auth) ────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=genera-con-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000

# ── Platform API ──────────────────────────────────────────────────────────────
# Clave API para autenticar solicitudes desde apps (Bearer token)
PLATFORM_API_KEY=sk_platform_xxx

# ── Webhook signing ───────────────────────────────────────────────────────────
# Secret para firmar webhooks hacia las apps (HMAC-SHA256)
PLATFORM_WEBHOOK_SECRET=wh_secret_xxx

# ── Cron Jobs ─────────────────────────────────────────────────────────────────
# Secret para validar llamadas de cron (Vercel Cron o crontab)
CRON_SECRET=cron_secret_xxx

# ── App URLs (override por entorno) ──────────────────────────────────────────
# URL del webhook de Turnflow (default: producción)
TURNFLOW_WEBHOOK_URL=http://localhost:3000/api/platform/webhook

# ── Wompi Payment Gateway (Phase 4) ────────────────────────────────────────────
# Wompi API credentials for payment processing
WOMPI_API_URL=https://api.wompi.co
WOMPI_PUBLIC_KEY=pub_prod_xxx    # Para tokenización en cliente (frontend)
WOMPI_PRIVATE_KEY=prv_prod_xxx   # Para transacciones en servidor (MANTENER SECRETO)
WOMPI_WEBHOOK_SECRET=wh_wompi_xxx # Para validar webhooks de Wompi
