{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "PLATFORM_DATABASE_URL",
    "AUTH_SECRET",
    "NEXT_PUBLIC_APP_URL",
    "RESEND_API_KEY",
    "AUTH_DATABASE_URL",
    "AUTH_SERVICE_API_KEY",
    "AUTH_COOKIE_DOMAIN",
    "AUTH_TRUSTED_ORIGINS",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "NOTIFICATIONS_DATABASE_URL",
    "NOTIFICATIONS_API_KEY",
    "NOTIFICATIONS_URL",
    "AUDIT_DATABASE_URL",
    "AUDIT_API_KEY",
    "AUDIT_URL"
  ],
  "tasks": {
    "build": {
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "type-check": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    }
  }
}
